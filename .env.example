# Copia este archivo como ".env" (o exporta las variables en tu shell / configuración
# de ejecución del IDE) y NUNCA commitees el ".env" real. Este archivo de ejemplo sí
# se commitea porque solo contiene valores de referencia, no secretos reales.

# Secreto usado para firmar los JWT (HS256). Debe ser una cadena base64 de al menos
# 256 bits (32 bytes). Genera una nueva con:
#   openssl rand -base64 32
JWT_SECRET=f16+5dQnMlaAAaM6RCzUkbe8PpVQXowBmV8jUMJR2Ak=

# Tiempo de expiración del token en milisegundos (3600000 = 1 hora)
JWT_EXPIRATION=3600000
